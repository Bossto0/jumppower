local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local speed = 16
local minSpeed = 4
local maxSpeed = 100
local step = 4

local humanoid

local function applySpeed()
	if humanoid then
		humanoid.WalkSpeed = speed
	end
end

local function setupCharacter(character)
	humanoid = character:WaitForChild("Humanoid")
	applySpeed()
end

if player.Character then
	setupCharacter(player.Character)
end

player.CharacterAdded:Connect(setupCharacter)

local gui = Instance.new("ScreenGui")
gui.Name = "LocalSpeedGui"
gui.ResetOnSpawn = false
gui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 90)
frame.Position = UDim2.new(0, 20, 0, 20)
frame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
frame.Parent = gui

local label = Instance.new("TextLabel")
label.Size = UDim2.new(1, 0, 0, 35)
label.BackgroundTransparency = 1
label.TextColor3 = Color3.fromRGB(255, 255, 255)
label.TextScaled = true
label.Font = Enum.Font.GothamBold
label.Parent = frame

local minus = Instance.new("TextButton")
minus.Size = UDim2.new(0.5, -5, 0, 45)
minus.Position = UDim2.new(0, 0, 0, 40)
minus.Text = "-"
minus.TextScaled = true
minus.Font = Enum.Font.GothamBold
minus.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
minus.TextColor3 = Color3.fromRGB(255, 255, 255)
minus.Parent = frame

local plus = Instance.new("TextButton")
plus.Size = UDim2.new(0.5, -5, 0, 45)
plus.Position = UDim2.new(0.5, 5, 0, 40)
plus.Text = "+"
plus.TextScaled = true
plus.Font = Enum.Font.GothamBold
plus.BackgroundColor3 = Color3.fromRGB(60, 160, 80)
plus.TextColor3 = Color3.fromRGB(255, 255, 255)
plus.Parent = frame

local function updateGui()
	label.Text = "Speed: " .. speed
	applySpeed()
end

minus.MouseButton1Click:Connect(function()
	speed = math.max(minSpeed, speed - step)
	updateGui()
end)

plus.MouseButton1Click:Connect(function()
	speed = math.min(maxSpeed, speed + step)
	updateGui()
end)

updateGui()
